{
  "expo": {
    "name": "SafeRoute",
    "slug": "saferoute",
    "scheme": "saferoute",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.saferoute.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SafeRoute uses your location to discover guardians and send SOS alerts.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.saferoute.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "c8a11fae-9d1f-4af2-a0a6-2b20ec58a0e1"
      }
    }
  }
}
